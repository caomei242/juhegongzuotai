{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist/server"
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
